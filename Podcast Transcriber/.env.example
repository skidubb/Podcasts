# =============================================================================
# Podcast Transcriber - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Required: API Keys
# -----------------------------------------------------------------------------

# OpenAI API key for generating embeddings
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API key for Claude answer generation
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Pinecone API key for cloud vector storage
# Get one at: https://www.pinecone.io/
PINECONE_API_KEY=pcsk_your-pinecone-key-here

# -----------------------------------------------------------------------------
# Required: Podcast Configuration
# -----------------------------------------------------------------------------

# RSS feed URL for your podcast
RSS_FEED_URL=https://your-podcast-rss-feed.com/feed.xml

# Display name for your podcast (used in UI and prompts)
PODCAST_NAME=Your Podcast Name

# Brief description of your podcast (used in AI system prompt)
# This helps Claude understand the context and tone of your content
PODCAST_DESCRIPTION=A podcast about [your topic] featuring conversations with [your guests]

# -----------------------------------------------------------------------------
# Optional: Customization
# -----------------------------------------------------------------------------

# Pinecone index name (defaults to slugified podcast name)
# Only alphanumeric and hyphens, max 45 chars
# PINECONE_INDEX_NAME=your-podcast-index

# Directory to store transcripts (defaults to ./transcripts)
# TRANSCRIPTS_DIR=./transcripts

# Whisper model for transcription: tiny, base, small, medium, large
# Larger = more accurate but slower
# WHISPER_MODEL=base
