# =============================================================================
# Streamlit Cloud Secrets Template
# =============================================================================
# For local development: Copy this to secrets.toml and fill in your values
# For Streamlit Cloud: Add these in your app's Settings > Secrets
# =============================================================================

# Required: API Keys
OPENAI_API_KEY = "sk-your-openai-key-here"
ANTHROPIC_API_KEY = "sk-ant-your-anthropic-key-here"
PINECONE_API_KEY = "pcsk_your-pinecone-key-here"

# Required: Podcast Configuration
PODCAST_NAME = "Your Podcast Name"
PODCAST_DESCRIPTION = "A podcast about [your topic] featuring conversations with [your guests]"

# Optional: Custom Pinecone index name (defaults to slugified podcast name)
# PINECONE_INDEX_NAME = "your-podcast-index"
